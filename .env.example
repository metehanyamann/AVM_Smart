# Application Settings
APP_NAME=AVM Smart Track API
DEBUG=False
HOST=0.0.0.0
PORT=8000
API_VERSION=v1

# Milvus Configuration
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=face_embeddings_512

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# PostgreSQL Configuration
DATABASE_URL=postgresql://admin:root@localhost:5432/avm_db

# Security / JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ML Model Configuration
FACE_DETECTION_MODEL=retinaface
FACE_RECOGNITION_MODEL=arcface
CONFIDENCE_THRESHOLD=0.5
MATCH_THRESHOLD=0.3

# Real-Time Tracking
TRACKING_MATCH_THRESHOLD=0.6
TRACKING_TIMEOUT_SECONDS=30.0
TRACKING_MAX_TRACKS=1000

# Face Token
FACE_TOKEN_EXPIRY_MINUTES=60
FACE_TOKEN_MAX_COUNT=10000

# Logging
LOG_LEVEL=INFO

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080"]
CORS_CREDENTIALS=true
CORS_METHODS=["*"]
CORS_HEADERS=["*"]
